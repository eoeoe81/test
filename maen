// Deklarasi di atas onCreate
private EditText edtUsername, edtPassword;
private Button btnLogin;

// Di dalam onCreate
edtUsername = findViewById(R.id.edtUsername); // Sesuaikan ID dengan di XML
edtPassword = findViewById(R.id.edtPassword);
btnLogin = findViewById(R.id.btnLogin);

btnLogin.setOnClickListener(new View.OnClickListener() {
    @Override
    public void onClick(View view) {
        // Ambil inputan teks
        String user = edtUsername.getText().toString();
        String pass = edtPassword.getText().toString();

        // Validasi sederhana (jika username "ade" seperti di gambar)
        if(user.equals("ade") && pass.equals("1234")) {
            // Berhasil login, pindah ke Dashboard
            Intent intent = new Intent(view.getContext(), DashboardActivity.class);
            startActivity(intent);
        } else {
            // Gagal login, munculkan Toast (seperti yang di-comment di kodemu)
            Toast.makeText(view.getContext(), "Username/Password Salah", Toast.LENGTH_SHORT).show();
        }
    }
});
