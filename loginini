package edu.uph.m24si1.myapplication;

import android.content.Intent;
import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;
import android.widget.Toast;
import androidx.appcompat.app.AppCompatActivity;

public class LoginActivity extends AppCompatActivity {
    // Deklarasi variabel komponen UI
    private EditText edtUsername, edtPassword;
    private Button btnLogin;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        // Menghubungkan file Java dengan layout XML login
        setContentView(R.layout.activity_login); 

        // Inisialisasi komponen berdasarkan ID di XML
        edtUsername = findViewById(R.id.edtUsername);
        edtPassword = findViewById(R.id.edtPassword);
        btnLogin = findViewById(R.id.btnLogin);

        // Logika aksi klik tombol Login
        btnLogin.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View view) {
                // Mengambil nilai teks dan menghapus spasi di awal/akhir
                String username = edtUsername.getText().toString().trim();
                String password = edtPassword.getText().toString().trim();

                // Validasi 1: Memeriksa apakah ada field yang kosong
                if (username.isEmpty() || password.isEmpty()) {
                    Toast.makeText(LoginActivity.this, "Username dan Password tidak boleh kosong", Toast.LENGTH_SHORT).show();
                } else {
                    // Validasi 2: Memeriksa akurasi data Kredensial
                    if (username.equals("ade") && password.equals("uts123")) {
                        Toast.makeText(LoginActivity.this, "Login Berhasil", Toast.LENGTH_SHORT).show();

                        // Inisialisasi Intent untuk pindah ke FormPetActivity
                        Intent intent = new Intent(LoginActivity.this, FormPetActivity.class);
                        startActivity(intent);
                        
                        // Menghancurkan LoginActivity agar tidak bisa diakses kembali via tombol back
                        finish(); 
                    } else {
                        Toast.makeText(LoginActivity.this, "Username atau Password salah", Toast.LENGTH_SHORT).show();
                    }
                }
            }
        });
    }
}
